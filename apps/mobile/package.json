    "expo": "^54.0.0",
    "expo-image-picker": "~16.0.6",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "zod": "^3.24.2"
